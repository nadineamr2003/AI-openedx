MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
HF_TOKEN=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
FIREWORKS_API_KEY=
FIREWORKS_API_BASE=https://api.fireworks.ai/inference/v1
MISTRAL_API_KEY=
MISTRAL_API_BASE=https://api.mistral.ai/v1

# provider-level order
PROVIDER_ORDER=groq,cerebras,fireworks,mistral,huggingface,openrouter,gemini

# model lists per provider
CEREBRAS_MODELS=llama-3.1-8b,qwen-3-235b-a22b-instruct-2507
FIREWORKS_MODELS=accounts/fireworks/models/deepseek-v3p1,accounts/fireworks/models/deepseek-v3p2
GEMINI_MODELS=gemini-3-flash-preview
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
MISTRAL_MODELS=mistral-small-latest,mistral-medium-latest,mistral-large-latest
OPENROUTER_MODELS=openrouter/free,openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,z-ai/glm-4.5-air:free,google/gemma-4-26b-a4b-it:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free,google/gemma-3-4b-it:free

HF_MODELS=meta-llama/Llama-3.1-8B-Instruct:cerebras
